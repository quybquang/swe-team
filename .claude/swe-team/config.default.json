{
  "$schema": "../references/config-schema.json",
  "version": "0.4.0",
  "models": {
    "lead": "opus",
    "coder": "sonnet",
    "verifier_mech": "haiku",
    "verifier_sem": "sonnet",
    "pr": "sonnet"
  },
  "budget": {
    "max_tokens": 2000000,
    "max_usd": 15.00,
    "warn_pct": 80
  },
  "limits": {
    "max_iterations": { "S": 2, "M": 4, "L": 6 },
    "max_replans": 2,
    "stuck_identical_output": 3,
    "stuck_file_churn": 5,
    "max_files_per_task": 10,
    "max_plan_tasks": 15,
    "max_plan_loc": 500
  },
  "branch": {
    "base": "dev",
    "prefix": "swe/",
    "auto_detect_base": true
  },
  "verification": {
    "test_cmd": "auto",
    "lint_cmd": "auto",
    "typecheck_cmd": "auto",
    "test_globs": ["**/*.test.*", "**/*.spec.*", "**/tests/**", "**/test/**"],
    "allow_flaky_retry": true
  },
  "clarify": {
    "enabled": true,
    "mode": "autonomous",
    "max_questions": 5
  },
  "security": {
    "enabled": true,
    "fail_on": ["critical", "high"],
    "warn_on": ["medium"]
  },
  "retro": {
    "enabled": true,
    "max_learnings_per_run": 5,
    "learnings_window": 10
  },
  "phases": {
    "define_threshold": 3,
    "force_define": false,
    "skip_define": false,
    "skip_clarify": false
  },
  "gh": {
    "pr_labels": ["ai-generated", "swe-team"],
    "pr_draft": false,
    "require_clean_working_tree": true
  },
  "knowledge": {
    "sources": [],
    "write_target": ""
  },
  "dod": {
    "docs_gate": true,
    "docs_gate_fail_on_miss": false,
    "breaking_change_flag": "block",
    "dep_audit_fail_on": ["critical", "high"],
    "audit_dev_deps": false
  }
}
