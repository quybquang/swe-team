{
  "$schema": "../references/config-schema.json",
  "version": "0.1.0",
  "models": {
    "lead": "opus",
    "coder": "sonnet",
    "verifier_mech": "haiku",
    "verifier_sem": "sonnet",
    "pr": "sonnet"
  },
  "budget": {
    "max_tokens": 2000000,
    "max_usd": 15.00,
    "warn_pct": 80
  },
  "limits": {
    "max_iterations": { "S": 2, "M": 4, "L": 6 },
    "max_replans": 2,
    "stuck_identical_output": 3,
    "stuck_file_churn": 5,
    "max_files_per_task": 10,
    "max_plan_tasks": 15,
    "max_plan_loc": 500
  },
  "branch": {
    "base": "dev",
    "prefix": "swe/",
    "auto_detect_base": true
  },
  "verification": {
    "test_cmd": "auto",
    "lint_cmd": "auto",
    "typecheck_cmd": "auto",
    "test_globs": ["**/*.test.*", "**/*.spec.*", "**/tests/**", "**/test/**"],
    "allow_flaky_retry": true
  },
  "phases": {
    "define_threshold": 3,
    "force_define": false,
    "skip_define": false
  },
  "gh": {
    "pr_labels": ["ai-generated", "swe-team"],
    "pr_draft": false,
    "require_clean_working_tree": true
  }
}
