{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swe-team.dev/schemas/tasks.json",
  "title": "swe-team tasks.json",
  "description": "Authoritative task list for a run. Version increments on each re-plan. Append-only.",
  "type": "object",
  "required": ["version", "tasks"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "size", "touch_files", "acceptance", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^T[0-9]+$" },
          "title": { "type": "string", "minLength": 1, "maxLength": 120 },
          "description": { "type": "string", "minLength": 1 },
          "size": { "type": "string", "enum": ["S", "M", "L"] },
          "touch_files": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "maxItems": 10
          },
          "acceptance": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "failed"]
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "pattern": "^T[0-9]+$" }
          },
          "parallelizable_with": {
            "type": "array",
            "items": { "type": "string", "pattern": "^T[0-9]+$" }
          },
          "iteration_count": { "type": "integer", "minimum": 0 },
          "last_commit_sha": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
